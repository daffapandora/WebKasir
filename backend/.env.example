APP_NAME=KasirPro
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://kasirpro.local

# Localization
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# Maintenance
APP_MAINTENANCE_DRIVER=file

# PHP CLI Workers
PHP_CLI_SERVER_WORKERS=4

# Hashing
BCRYPT_ROUNDS=12

# Logging & Debugging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration (PostgreSQL 15+)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kasirpro
DB_USERNAME=kasirpro_user
DB_PASSWORD=
DB_SSLMODE=prefer

# Session & Broadcast
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Cache & Sessions
CACHE_STORE=redis
CACHE_PREFIX=kasirpro_

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@kasirpro.local"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# API Documentation
API_VERSION=v1
API_PREFIX=/api

# JWT Authentication
JWT_SECRET=
JWT_EXPIRATION=604800

# Payment Gateways
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENVIRONMENT=production

QRIS_MERCHANT_ID=
QRIS_MERCHANT_KEY=

# EDC Integration
EDC_API_URL=http://edc-gateway.local/api
EDC_API_KEY=
EDC_TIMEOUT=30

# Omnichannel Platform APIs
GOFOOD_API_URL=https://api.gofood.co.id/v1
GOFOOD_REST_ID=
GOFOOD_AUTH_TOKEN=

GRABFOOD_API_URL=https://merchant-api.grab.com/merchant/v1
GRABFOOD_REST_ID=
GRABFOOD_AUTH_TOKEN=

# WebSocket & Broadcasting
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

REVERB_SERVER_PORT=8080
REVERB_SCHEME=http
REVERB_HOST=127.0.0.1

# Security
PIN_HASH_ALGORITHM=bcrypt
PIN_LENGTH=4
PIN_MAX_ATTEMPTS=3

# Offline Sync
SYNC_MAX_RETRIES=3
SYNC_RETRY_DELAY=5000
SYNC_BATCH_SIZE=50
SYNC_CONFLICT_STRATEGY=last_write_wins

# Sentry (Error Tracking)
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production

VITE_APP_NAME="${APP_NAME}"
