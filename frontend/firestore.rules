rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cabang (Branches)
    match /branches/{branchId} {
      allow read, write: if true;
    }
    
    // Kategori Produk (Categories)
    match /categories/{categoryId} {
      allow read, write: if true;
    }
    
    // Produk (Products)
    match /products/{productId} {
      allow read, write: if true;
    }
    
    // Pelanggan (Customers)
    match /customers/{customerId} {
      allow read, write: if true;
    }
    
    // Pemasok (Suppliers)
    match /suppliers/{supplierId} {
      allow read, write: if true;
    }
    
    // Konfigurasi Pajak (Tax Configs)
    match /tax_configs/{configId} {
      allow read, write: if true;
    }
    
    // Diskon / Promo (Discounts)
    match /discounts/{discountId} {
      allow read, write: if true;
    }
    
    // Karyawan / Pengguna (Users)
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Riwayat Pergerakan Stok (Stock Movements)
    match /stock_movements/{movementId} {
      allow read, write: if true;
    }
    
    // Log Audit (Audit Logs)
    match /audit_logs/{logId} {
      allow read, write: if true;
    }
    
    // Transaksi Penjualan (Transactions)
    match /transactions/{transactionId} {
      allow read, write: if true;
    }
    
    // Shift Kasir (Shifts)
    match /shifts/{shiftId} {
      allow read, write: if true;
    }
    
    // Transaksi Loyalitas / Poin (Loyalty Transactions)
    match /loyalty_transactions/{loyaltyId} {
      allow read, write: if true;
    }
  }
}
